<?xml version="1.0" encoding="utf-8"?>
<!--
  MSIX Manifest for OCR Master
  Publisher identity from Partner Center (Product Identity page).
  Replace Assets\ placeholder images with real branded images before Store submission.
-->
<Package
  xmlns="http://schemas.microsoft.com/appx/manifest/foundation/windows10"
  xmlns:uap="http://schemas.microsoft.com/appx/manifest/uap/windows10"
  xmlns:rescap="http://schemas.microsoft.com/appx/manifest/foundation/windows10/restrictedcapabilities"
  IgnorableNamespaces="uap rescap">

  <Identity
    Name="WS2026.OCRMaster"
    Publisher="CN=5173FDE3-098A-4163-8004-3AC3FD6CBE2D"
    Version="1.2.1.0"
    ProcessorArchitecture="x64" />

  <Properties>
    <DisplayName>OCR Master</DisplayName>
    <PublisherDisplayName>WS2026</PublisherDisplayName>
    <Logo>Assets\StoreLogo.png</Logo>
    <!-- StoreLogo: 50x50 px -->
  </Properties>

  <Dependencies>
    <!-- Windows 10 1809 (build 17763) minimum — required for winget support -->
    <TargetDeviceFamily
      Name="Windows.Desktop"
      MinVersion="10.0.17763.0"
      MaxVersionTested="10.0.22621.0" />
  </Dependencies>

  <Resources>
    <Resource Language="en-us" />
  </Resources>

  <Applications>
    <Application
      Id="OCRMaster"
      Executable="OCRMaster\OCRMaster.exe"
      EntryPoint="Windows.FullTrustApplication">
      <uap:VisualElements
        DisplayName="OCR Master"
        Description="Bank statement extractor — proof of concept technology demonstrator. Use at your own risk."
        BackgroundColor="#1e3a5f"
        Square150x150Logo="Assets\Square150x150Logo.png"
        Square44x44Logo="Assets\Square44x44Logo.png">
        <!-- Square150x150Logo: 150x150 px (also provide 200x200, 300x300 scaled) -->
        <!-- Square44x44Logo:   44x44 px  (also provide 55x55, 88x88, 176x176 scaled) -->
        <uap:DefaultTile
          Wide310x150Logo="Assets\Wide310x150Logo.png"
          ShortName="OCR Master">
          <!-- Wide310x150Logo: 310x150 px -->
        </uap:DefaultTile>
        <uap:SplashScreen Image="Assets\SplashScreen.png" BackgroundColor="#1e3a5f" />
        <!-- SplashScreen: 620x300 px -->
      </uap:VisualElements>
    </Application>
  </Applications>

  <Capabilities>
    <!-- Required for Win32 / PyInstaller apps running outside the sandbox -->
    <rescap:Capability Name="runFullTrust" />
  </Capabilities>

</Package>
