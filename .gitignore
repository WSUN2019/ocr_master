# ── Financial data — never commit any of this ─────────────────────────────────
input_files/*
!input_files/.gitkeep
output/

# Database
ocr_master.db
*.db
*.db-shm
*.db-wal

# Statement files (any format) — but allow docs/ screenshots and sample template
*.pdf
*.jpg
*.jpeg
*.png
!docs/*.png
!templates/MDBank.png
*.tif
*.tiff

# Exported data
*.csv
*.xlsx

# Templates (contain layout coords derived from real statements)
templates/*
# Allow folder anchor and sample/test template
!templates/.gitkeep
!templates/md_bank.json
!templates/MDBank.png

# User preferences
config.json

# Logs
*.log

# Python
__pycache__/
*.py[cod]
*.pyo
.eggs/
*.egg-info/
dist/
# PyInstaller build output — but keep source files in build/
build/*.exe
build/*.pkg
build/Output/
build/work/

# Virtual environments
.venv/
venv/
env/

# OS
.DS_Store
Thumbs.db

# Editor
.vscode/
.idea/
*.swp
*.swo

# Streamlit (legacy — no longer used)
.streamlit/
