# ── Financial data — never commit any of this ─────────────────────────────────
input_files/*
!input_files/.gitkeep
!input_files/Examples/
output/

# Database
ocr_master.db
*.db
*.db-shm
*.db-wal

# Statement files (any format) — but allow docs/ screenshots and sample files
*.pdf
*.jpg
*.jpeg
*.png
!docs/*.png
*.tif
*.tiff
!input_files/Examples/*

# Exported data
*.csv
*.xlsx

# Templates (contain layout coords derived from real statements)
templates/*
!templates/.gitkeep
!templates/saiminbank.json

# User preferences
config.json

# Logs
*.log

# Python
__pycache__/
*.py[cod]
*.pyo
.eggs/
*.egg-info/
dist/
# PyInstaller build output — but keep source files in build/
build/*.exe
build/*.pkg
build/Output/
build/work/
build/OCRMaster/

# Virtual environments
.venv/
venv/
env/

# OS
.DS_Store
Thumbs.db

# Editor
.vscode/
.idea/
*.swp
*.swo
